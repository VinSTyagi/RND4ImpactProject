# Keep the build context small and Linux-clean. Each Dockerfile copies only its
# module tree; these excludes shrink context upload when building from repo root.

# Local virtualenvs (Windows-built, multi-GB, wrong platform)
.venv/
.venv-stability/
env/
venv/
ENV/

# Windows-resolved lock (re-resolved on Linux in the builder)
uv.lock

# Vendored / cloned trees
vendor/

# Other pipeline modules (not baked into script_setup images)
src/shared/
src/rnd4impact/

# VCS + IDE + agent tooling
.git/
.gitignore
.vscode/
.cursor/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Python caches
**/__pycache__/
*.py[cod]
*$py.class

# Pipeline outputs and large local artifacts (mounted at runtime, not baked in)
data/stage_*.jsonl
data/*/
reports/
docs/
*.pdf

# Docker artifacts themselves
docker/**/.env
