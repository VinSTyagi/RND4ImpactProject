# Copy this file to docker/.env (auto-loaded by docker compose from this folder).
# All values are optional; leave blank to run unauthenticated / online.

# Hugging Face token for gated/private model downloads.
HF_TOKEN=

# Restrict which GPU(s) the container sees (host GPU index, e.g. 0 or 0,1).
# Leave commented out to expose all reserved GPUs -- setting it empty hides them.
# CUDA_VISIBLE_DEVICES=0

# Fully offline mode: set both to 1 after prefetching weights into the hf_cache
# volume (e.g. via `docker compose run --rm prefetch-model`).
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# vLLM engine: keep 0 for script_setup (V0). Set 1 only if you need V1 features.
VLLM_USE_V1=0

# Model id used by the optional prefetch-model service.
MODEL=Qwen/Qwen3-4B-AWQ
