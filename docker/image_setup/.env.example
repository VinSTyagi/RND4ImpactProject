# Copy this file to docker/image_setup/.env (auto-loaded by docker compose).
# All values are optional; leave blank to run unauthenticated / online.

# Hugging Face token for gated/private model downloads.
HF_TOKEN=

# Restrict which GPU(s) the container sees (host GPU index, e.g. 0 or 0,1).
# CUDA_VISIBLE_DEVICES=0

# Fully offline mode: set both to 1 after models have been cached in hf_cache.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
